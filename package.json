{
  "name": "k",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dragoshont/k-core.git"
  },
  "homepage": "https://github.com/dragoshont/k-core#readme",
  "bugs": {
    "url": "https://github.com/dragoshont/k-core/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "tokens": "node scripts/generate-tokens.mjs",
    "storybook": "npm run tokens && storybook dev -p 6006 --no-open",
    "build": "npm run tokens && npm run build:server && storybook build --output-dir storybook-static",
    "build:server": "node scripts/build-server.mjs",
    "start:web": "node build/server/hosts/web/main.js",
    "migrate": "node build/server/bin/migrate.js",
    "admin": "node build/server/bin/k.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:contracts && npm run test:backend && npm run test:storybook && npm run test:map",
    "test:backend": "npm run build:server && node scripts/run-backend-tests.mjs",
    "test:contracts": "node scripts/validate-contracts.mjs && redocly lint --skip-rule operation-2xx-response contracts/http.capabilities.phase-3.openapi.yaml",
    "test:public-snapshot": "node scripts/check-public-snapshot.mjs",
    "test:dependency-licenses": "node scripts/check-dependency-licenses.mjs",
    "test:oss-gates": "node scripts/test-oss-gates.mjs && node scripts/check-image-inventory.mjs --self-test",
    "test:oss-core": "npm run test:oss-gates && npm run test:public-snapshot && npm run test:dependency-licenses && npm run test:contracts",
    "test:storybook": "vitest --project=storybook run",
    "test:map": "node scripts/validate-story-map.mjs",
    "test:visual": "node scripts/capture-stories.mjs"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "argon2": "^0.43.0",
    "cheerio": "^1.1.2",
    "fast-xml-parser": "^5.7.0",
    "ipaddr.js": "^2.2.0",
    "nodemailer": "^9.0.3",
    "openid-client": "^6.8.4",
    "pg": "^8.16.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.39.0",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/addon-vitest": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.5",
    "@vitejs/plugin-react": "latest",
    "@vitest/browser-playwright": "latest",
    "esbuild": "^0.28.1",
    "jose": "^6.2.3",
    "playwright": "latest",
    "storybook": "10.5.2",
    "typescript": "^5.9.0",
    "vite": "8.1.5",
    "vitest": "latest",
    "yazl": "^3.3.1"
  }
}
