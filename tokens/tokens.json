{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "k web tokens: paper, ink, moss, brass, and explicit status roles.",
  "ref": {
    "color": {
      "$type": "color",
      "paper": { "$value": { "colorSpace": "srgb", "components": [0.973, 0.965, 0.933], "hex": "#f8f6ee" } },
      "paper-raised": { "$value": { "colorSpace": "srgb", "components": [1, 0.996, 0.98], "hex": "#fffefa" } },
      "ink": { "$value": { "colorSpace": "srgb", "components": [0.075, 0.102, 0.086], "hex": "#131a16" } },
      "ink-muted": { "$value": { "colorSpace": "srgb", "components": [0.31, 0.337, 0.31], "hex": "#4f564f" } },
      "rule": { "$value": { "colorSpace": "srgb", "components": [0.77, 0.75, 0.69], "hex": "#c4c0b0" } },
      "moss": { "$value": { "colorSpace": "srgb", "components": [0.102, 0.31, 0.196], "hex": "#1a4f32" } },
      "moss-soft": { "$value": { "colorSpace": "srgb", "components": [0.86, 0.91, 0.866], "hex": "#dbe8dd" } },
      "brass": { "$value": { "colorSpace": "srgb", "components": [0.62, 0.43, 0.13], "hex": "#9e6e21" } },
      "amber-soft": { "$value": { "colorSpace": "srgb", "components": [0.98, 0.91, 0.72], "hex": "#fae8b8" } },
      "red": { "$value": { "colorSpace": "srgb", "components": [0.64, 0.11, 0.09], "hex": "#a31c17" } },
      "red-soft": { "$value": { "colorSpace": "srgb", "components": [0.96, 0.85, 0.82], "hex": "#f5d9d1" } }
    },
    "space": {
      "$type": "dimension",
      "1": { "$value": { "value": 4, "unit": "px" } },
      "2": { "$value": { "value": 8, "unit": "px" } },
      "3": { "$value": { "value": 12, "unit": "px" } },
      "4": { "$value": { "value": 16, "unit": "px" } },
      "5": { "$value": { "value": 24, "unit": "px" } },
      "6": { "$value": { "value": 32, "unit": "px" } },
      "7": { "$value": { "value": 48, "unit": "px" } }
    },
    "radius": {
      "$type": "dimension",
      "control": { "$value": { "value": 4, "unit": "px" } },
      "panel": { "$value": { "value": 6, "unit": "px" } }
    },
    "font": {
      "body": { "$type": "fontFamily", "$value": ["Verdana", "Geneva", "sans-serif"] },
      "display": { "$type": "fontFamily", "$value": ["Georgia", "Times New Roman", "serif"] }
    },
    "type": {
      "page-title-size": { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "page-title-line": { "$type": "dimension", "$value": { "value": 32, "unit": "px" } },
      "book-title-size": { "$type": "dimension", "$value": { "value": 21, "unit": "px" } },
      "book-title-line": { "$type": "dimension", "$value": { "value": 28, "unit": "px" } },
      "section-title-size": { "$type": "dimension", "$value": { "value": 18, "unit": "px" } },
      "section-title-line": { "$type": "dimension", "$value": { "value": 26, "unit": "px" } },
      "body-size": { "$type": "dimension", "$value": { "value": 16, "unit": "px" } },
      "body-line": { "$type": "dimension", "$value": { "value": 24, "unit": "px" } },
      "control-size": { "$type": "dimension", "$value": { "value": 15, "unit": "px" } },
      "control-line": { "$type": "dimension", "$value": { "value": 20, "unit": "px" } },
      "meta-size": { "$type": "dimension", "$value": { "value": 13, "unit": "px" } },
      "meta-line": { "$type": "dimension", "$value": { "value": 20, "unit": "px" } }
    },
    "stroke": {
      "$type": "dimension",
      "thin": { "$value": { "value": 1, "unit": "px" } },
      "strong": { "$value": { "value": 2, "unit": "px" } }
    },
    "motion": {
      "state-duration": { "$type": "duration", "$value": { "value": 120, "unit": "ms" } },
      "state-easing": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] }
    }
  },
  "sys": {
    "color": {
      "$type": "color",
      "surface": { "$value": "{ref.color.paper}" },
      "surface-raised": { "$value": "{ref.color.paper-raised}" },
      "text": { "$value": "{ref.color.ink}" },
      "text-muted": { "$value": "{ref.color.ink-muted}" },
      "border": { "$value": "{ref.color.rule}" },
      "control-border": { "$value": "{ref.color.ink-muted}" },
      "action": { "$value": "{ref.color.moss}" },
      "action-subtle": { "$value": "{ref.color.moss-soft}" },
      "focus": { "$value": "{ref.color.brass}" },
      "warning": { "$value": "{ref.color.brass}" },
      "warning-subtle": { "$value": "{ref.color.amber-soft}" },
      "danger": { "$value": "{ref.color.red}" },
      "danger-subtle": { "$value": "{ref.color.red-soft}" },
      "success": { "$value": "{ref.color.moss}" },
      "status": {
        "neutral-foreground": { "$value": "{ref.color.ink-muted}" },
        "neutral-background": { "$value": "{ref.color.paper-raised}" },
        "warning-foreground": { "$value": "{ref.color.ink}" },
        "warning-background": { "$value": "{ref.color.amber-soft}" },
        "success-foreground": { "$value": "{ref.color.moss}" },
        "success-background": { "$value": "{ref.color.moss-soft}" },
        "danger-foreground": { "$value": "{ref.color.red}" },
        "danger-background": { "$value": "{ref.color.red-soft}" }
      }
    },
    "space": {
      "$type": "dimension",
      "inline": { "$value": "{ref.space.2}" },
      "control": { "$value": "{ref.space.3}" },
      "section": { "$value": "{ref.space.6}" },
      "page": { "$value": "{ref.space.5}" }
    },
    "font": {
      "body": { "$type": "fontFamily", "$value": "{ref.font.body}" },
      "display": { "$type": "fontFamily", "$value": "{ref.font.display}" }
    },
    "type": {
      "page-title": {
        "family": { "$type": "fontFamily", "$value": "{ref.font.body}" },
        "size": { "$type": "dimension", "$value": "{ref.type.page-title-size}" },
        "line-height": { "$type": "dimension", "$value": "{ref.type.page-title-line}" },
        "weight": { "$type": "fontWeight", "$value": 700 }
      },
      "book-title": {
        "family": { "$type": "fontFamily", "$value": "{ref.font.display}" },
        "size": { "$type": "dimension", "$value": "{ref.type.book-title-size}" },
        "line-height": { "$type": "dimension", "$value": "{ref.type.book-title-line}" },
        "weight": { "$type": "fontWeight", "$value": 700 }
      },
      "section-title": {
        "family": { "$type": "fontFamily", "$value": "{ref.font.body}" },
        "size": { "$type": "dimension", "$value": "{ref.type.section-title-size}" },
        "line-height": { "$type": "dimension", "$value": "{ref.type.section-title-line}" },
        "weight": { "$type": "fontWeight", "$value": 700 }
      },
      "body": {
        "family": { "$type": "fontFamily", "$value": "{ref.font.body}" },
        "size": { "$type": "dimension", "$value": "{ref.type.body-size}" },
        "line-height": { "$type": "dimension", "$value": "{ref.type.body-line}" },
        "weight": { "$type": "fontWeight", "$value": 400 }
      },
      "control": {
        "family": { "$type": "fontFamily", "$value": "{ref.font.body}" },
        "size": { "$type": "dimension", "$value": "{ref.type.control-size}" },
        "line-height": { "$type": "dimension", "$value": "{ref.type.control-line}" },
        "weight": { "$type": "fontWeight", "$value": 700 }
      },
      "meta": {
        "family": { "$type": "fontFamily", "$value": "{ref.font.body}" },
        "size": { "$type": "dimension", "$value": "{ref.type.meta-size}" },
        "line-height": { "$type": "dimension", "$value": "{ref.type.meta-line}" },
        "weight": { "$type": "fontWeight", "$value": 400 }
      }
    },
    "stroke": {
      "thin": { "$type": "dimension", "$value": "{ref.stroke.thin}" },
      "strong": { "$type": "dimension", "$value": "{ref.stroke.strong}" }
    },
    "focus": {
      "offset": { "$type": "dimension", "$value": { "value": 2, "unit": "px" } }
    },
    "motion": {
      "state-duration": { "$type": "duration", "$value": "{ref.motion.state-duration}" },
      "state-easing": { "$type": "cubicBezier", "$value": "{ref.motion.state-easing}" }
    }
  },
  "comp": {
    "shell": {
      "max-width": { "$type": "dimension", "$value": { "value": 720, "unit": "px" } },
      "page-gap": { "$type": "dimension", "$value": "{sys.space.section}" }
    },
    "button": {
      "min-height": { "$type": "dimension", "$value": { "value": 48, "unit": "px" } },
      "radius": { "$type": "dimension", "$value": "{ref.radius.control}" },
      "background": { "$type": "color", "$value": "{sys.color.action}" },
      "label": { "$type": "color", "$value": "{ref.color.paper-raised}" }
    },
    "input": {
      "min-height": { "$type": "dimension", "$value": { "value": 48, "unit": "px" } },
      "radius": { "$type": "dimension", "$value": "{ref.radius.control}" },
      "background": { "$type": "color", "$value": "{sys.color.surface-raised}" },
      "border": { "$type": "color", "$value": "{sys.color.control-border}" }
    },
    "profilePicker": {
      "gap": { "$type": "dimension", "$value": "{sys.space.control}" }
    },
    "search": {
      "gap": { "$type": "dimension", "$value": "{sys.space.inline}" }
    },
    "result": {
      "block-gap": { "$type": "dimension", "$value": "{ref.space.4}" },
      "rule": { "$type": "color", "$value": "{sys.color.border}" }
    },
    "capabilityBadge": {
      "metadata-background": { "$type": "color", "$value": "{sys.color.surface-raised}" },
      "candidate-background": { "$type": "color", "$value": "{sys.color.warning-subtle}" },
      "deliverable-background": { "$type": "color", "$value": "{sys.color.action-subtle}" }
    },
    "notice": {
      "warning-background": { "$type": "color", "$value": "{sys.color.warning-subtle}" },
      "danger-background": { "$type": "color", "$value": "{sys.color.danger-subtle}" },
      "radius": { "$type": "dimension", "$value": "{ref.radius.panel}" }
    },
    "timeline": {
      "$description": "Operation, stage, and delivery states consume the semantic sys.color.status foreground/background pairs; these aliases cover structural timeline marks only.",
      "rule": { "$type": "color", "$value": "{sys.color.border}" },
      "active": { "$type": "color", "$value": "{sys.color.action}" },
      "failed": { "$type": "color", "$value": "{sys.color.danger}" }
    },
    "navigation": {
      "min-height": { "$type": "dimension", "$value": { "value": 56, "unit": "px" } }
    },
    "cover": {
      "thumbnail-width": { "$type": "dimension", "$value": { "value": 72, "unit": "px" } },
      "thumbnail-height": { "$type": "dimension", "$value": { "value": 108, "unit": "px" } },
      "detail-width": { "$type": "dimension", "$value": { "value": 120, "unit": "px" } },
      "detail-height": { "$type": "dimension", "$value": { "value": 180, "unit": "px" } }
    }
  }
}
