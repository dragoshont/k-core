{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://k.example.invalid/contracts/provider-token-keyring.schema.json",
  "title": "k provider token keyring references",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "activeKeyId", "keys"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "activeKeyId": { "$ref": "#/$defs/keyId" },
    "keys": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["keyId", "keyEnv"],
        "properties": {
          "keyId": { "$ref": "#/$defs/keyId" },
          "keyEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,127}$" }
        }
      }
    }
  },
  "$defs": {
    "keyId": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,64}$" }
  }
}
