# Copy to an ignored environment file and replace every angle-bracket placeholder.
# Generate each application key independently with at least 32 random bytes.
DATABASE_URL=postgres://k:<database-password>@<database-host>:5432/k
PUBLIC_ORIGIN=https://k.example.invalid
TRUSTED_PROXY_CIDRS=10.0.0.0/8
ALLOWED_PRIVATE_CLIENT_CIDRS=10.0.0.0/8
OUTBOUND_CONTACT=operator@example.invalid
PIN_PEPPER=<generate-at-least-32-random-bytes>
PIN_REUSE_SECRET=<generate-at-least-32-random-bytes>
SESSION_SIGNING_KEY=<generate-at-least-32-random-bytes>
SOURCE_HASH_SECRET=<generate-at-least-32-random-bytes>
PUBLIC_PLUGIN_DIR=./plugins
PORT=3000
QUARANTINE_DIR=./data/quarantine

# Optional non-secret profile aliases. The file must match contracts/profile-config.schema.json.
# PROFILE_CONFIG_FILE=<path-to-profile-config.json>

# Optional future private plugin payload. Mount it read-only and keep it distinct from PUBLIC_PLUGIN_DIR.
# The core repository and image do not implement or distribute this payload.
# PRIVATE_PLUGIN_DIR=<read-only-private-plugin-root>

# Optional integrations remain unavailable until their reviewed configuration and
# secrets are provided through the deployment's secret store.
# GOOGLE_BOOKS_API_KEY=<provider-api-key>
# PROVIDER_REGISTRATIONS_FILE=<path-to-provider-registrations.json>
# PROVIDER_TOKEN_KEYRING_FILE=<path-to-provider-token-keyring.json>
# SMTP_HOST=<smtp-host>
# SMTP_PORT=587
# SMTP_USER=<smtp-user>
# SMTP_PASSWORD=<smtp-password>
# SMTP_FROM=<sender-address>