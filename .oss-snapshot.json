{
  "version": 1,
  "candidateSource": "git-tracked-and-untracked-nonignored",
  "maxFileBytes": 5242880,
  "excludedPaths": [
    ".DS_Store"
  ],
  "excludedPrefixes": [
    ".architrave/runs/",
    ".git/",
    "artifacts/",
    "build/",
    "data/",
    "node_modules/",
    "storybook-static/"
  ],
  "publicPluginEntries": [
    "google-books",
    "google-gmail",
    "internet-archive",
    "lib",
    "login-with-amazon",
    "project-gutenberg",
    "public-inventory.json",
    "standard-ebooks"
  ],
  "secretFilenamePatterns": [
    "(^|/)(\\.env($|\\.(?!example$))|id_(rsa|dsa|ecdsa|ed25519)(\\.pub)?$)",
    "(^|/)[^/]+\\.(key|p12|pfx|pem)$",
    "(^|/)(credentials|secrets?)(\\.[^/]*)?$"
  ],
  "forbiddenTextPatterns": [
    {
      "rule": "proprietary-license-marker",
      "pattern": "LicenseRef-Propr(?:ietary)|Commons[ -]Clause"
    },
    {
      "rule": "absolute-local-user-path",
      "pattern": "(?:^|[\\s'\"=(])(?:/Users/[^/\\s'\"]+|/home/[^/\\s'\"]+|[A-Za-z]:\\\\Users\\\\[^\\\\\\s'\"]+)"
    },
    {
      "rule": "private-package-reference",
      "pattern": "(?:ghcr\\.io/(?!dragoshont/k-core(?=[^A-Za-z0-9._-]|$))|npm\\.pkg\\.github\\.com/)"
    },
    {
      "rule": "private-key-material",
      "pattern": "-----BEGIN (?:RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----"
    },
    {
      "rule": "high-confidence-access-token",
      "pattern": "(?:gh[pousr]_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{40,}|AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|xox[baprs]-[A-Za-z0-9-]{20,}|sk_live_[A-Za-z0-9]{20,}|AIza[0-9A-Za-z_-]{35})"
    }
  ]
}